ANTHROPIC_API_KEY=your-key-here
OPENAI_API_KEY=your-key-here

# Pre-issued admin token used by `gollm purge` (wipes synthetic data between
# runs). Read by name from the app config's admin.token_env. Use a per-env
# file (.env.staging, .env.production) for real tokens; this is the template.
VOTERBLOC_ADMIN_TOKEN=your-admin-token-here

# Clerk issuer URL for `gollm serve`. When set, the engine validates Clerk
# JWTs on /v1/* and rejects unauthenticated requests. Leave blank for local
# dev with no auth (the existing CLI workflow continues to work). Format:
# https://your-app.clerk.accounts.dev (find it in your Clerk dashboard).
COHORT_CLERK_ISSUER=
